{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing points and earned badges.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The Google auth UID"
        },
        "points": {
          "type": "number",
          "description": "Total points accumulated"
        },
        "badges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of badge IDs earned"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of profile creation"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of last update"
        }
      },
      "required": ["userId", "points", "badges", "createdAt", "updatedAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A single chat session for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "messages": {
          "type": "array",
          "description": "List of messages in this session, serialized"
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["id", "userId", "title", "messages", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile document."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Chat sessions belonging to a user."
    }
  }
}
